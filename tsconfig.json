{
    "compilerOptions": {
    "target": "ESNext",
        "module": "ESNext",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "moduleResolution": "bundler",
        "strict": true,
        "noImplicitAny": true,
        "allowJs": true,
        "isolatedModules": true,
        "noEmit": true,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
},
    "include": ["**/*.ts", "**/*.js"],
    "exclude": ["node_modules"]
}